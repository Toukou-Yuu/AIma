# LLM 牌手（可选）。复制为 .env 后填入，勿提交真实密钥。
# pip install -e ".[llm]"
# 在仓库根目录执行 python -m llm 时，会自动加载本目录下的 .env（python-dotenv）。

# AIMA_LLM_PROVIDER=openai
# AIMA_OPENAI_API_KEY=
# AIMA_OPENAI_BASE_URL=https://api.openai.com/v1
# AIMA_OPENAI_MODEL=gpt-4o-mini

# AIMA_LLM_PROVIDER=anthropic
# AIMA_ANTHROPIC_API_KEY=
# AIMA_ANTHROPIC_BASE_URL=https://api.anthropic.com
# AIMA_ANTHROPIC_MODEL=claude-3-5-haiku-20241022

# AIMA_LLM_TIMEOUT_SEC=120
# AIMA_LLM_MAX_TOKENS=1024
